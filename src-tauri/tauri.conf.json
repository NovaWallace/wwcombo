{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WW Combo Trainer",
  "version": "0.1.0",
  "identifier": "com.novawallace.wwcombo",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WW Combo Trainer",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Combo Overlay",
        "url": "overlay.html",
        "width": 980,
        "height": 118,
        "x": 160,
        "y": 36,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
